# Порт, на якому піднімається proxy-сервер
PORT=3000

# true — довантажує тестові ЦСК (CAs.Test.json) на додачу до бойових (CAs.json)
# false — production-режим, тільки CAs.json
ENABLE_TEST_MODE=true

# Список origin'ів (через кому, без пробілів), яким дозволено користуватись цим proxy.
# Порожнє значення = дозволено з будь-якого сайту (НЕБЕЗПЕЧНО для production).
# Приклад: https://example.com,https://www.example.com
ALLOWED_ORIGINS=http://localhost:5173
